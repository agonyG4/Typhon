#!/usr/bin/env bash
set -euo pipefail

script_path="${BASH_SOURCE[0]}"
while [[ -L "$script_path" ]]; do
    script_dir="$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)"
    link_target="$(readlink -- "$script_path")"
    if [[ "$link_target" == /* ]]; then
        script_path="$link_target"
    else
        script_path="$script_dir/$link_target"
    fi
done
script_dir="$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)"
repo_dir="$(CDPATH= cd -- "$script_dir/.." && pwd)"

socket="${OBLIVION_ONE_SOCKET:-oblivion-one-sddm}"
profile="${OBLIVION_ONE_PROFILE:-auto}"
state_dir="${OBLIVION_ONE_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/oblivion-one}"
log_file="${OBLIVION_ONE_LOG_FILE:-$state_dir/session.log}"

usage() {
    cat <<EOF
start-oblivion-one

Starts Typhon as a native TTY/SDDM Wayland compositor.

Usage:
  start-oblivion-one [-- compositor args...]

Environment:
  OBLIVION_ONE_SOCKET    Wayland socket name (default: oblivion-one-sddm)
  OBLIVION_ONE_MODE      native KMS mode: auto, preferred, highres, highrr, or WIDTHxHEIGHT@HZ
  OBLIVION_ONE_CURSOR    native cursor backend: auto, hardware, or software
  OBLIVION_ONE_DIRECT_SCANOUT direct policy: off (default) or experimental-auto
  OBLIVION_ONE_TRIPLE_BUFFERING explicit output buffering: off, auto, or force
  OBLIVION_ONE_CURSOR_SCHEDULING cursor output scheduling: auto, piggyback, or software
  OBLIVION_ONE_SCANOUT_BACKEND native scanout: auto, gpu/native-egl-gbm (explicit Atomic), native-egl-gbm-opaque (rollback), gbm-cpu-write/cpu, or dumb
  OBLIVION_ONE_NATIVE_APP_GPU  native apps: auto, gpu, or cpu
  OBLIVION_ONE_PROFILE   auto, debug, or release (default: auto; native uses release)
  OBLIVION_ONE_PERF_LOG  set to 1/true/debug to emit structured native perf logs
  OBLIVION_ONE_LOG_FILE  native-session log path (default: ~/.local/state/oblivion-one/session.log)

Examples:
  start-oblivion-one
  OBLIVION_ONE_PROFILE=release start-oblivion-one
  start-oblivion-one -- kitty --class TyphonTerminal
  start-oblivion-one -- pavucontrol

Inherited WAYLAND_DISPLAY, WAYLAND_SOCKET, and DISPLAY variables do not select
another runtime. Native seat/DRM initialization either succeeds or fails with
native startup context.
EOF
}

warn_native_input_permissions() {
    if [[ "${OBLIVION_ONE_SKIP_INPUT_GROUP_CHECK:-0}" == "1" ]]; then
        return
    fi

    local input_group="${OBLIVION_ONE_INPUT_GROUP:-input}"
    local user_name="${USER:-$(id -un)}"
    local has_group=1
    if [[ "${OBLIVION_ONE_FORCE_INPUT_GROUP_WARNING:-0}" != "1" ]]; then
        if id -nG "$user_name" 2>/dev/null | tr ' ' '\n' | grep -qx -- "$input_group"; then
            has_group=0
        fi
    fi
    if [[ "$has_group" == "0" ]]; then
        return
    fi
    if ! getent group "$input_group" >/dev/null 2>&1; then
        return
    fi

    {
        echo "start-oblivion-one: native input needs access to /dev/input/event*."
        echo "start-oblivion-one: user '$user_name' is not in group '$input_group', so keyboard/mouse may be permission denied."
        echo "start-oblivion-one: run: $repo_dir/bin/install-start-oblivion-one --input-permissions"
        echo "start-oblivion-one: then log out and log back in before starting the native session again."
    } >&2
}

case "${1:-}" in
    -h|--help|help)
        usage
        exit 0
        ;;
esac

for removed_env in OBLIVION_ONE_OUTPUT OBLIVION_ONE_RENDERER; do
    if [[ -n "${!removed_env:-}" ]]; then
        echo "start-oblivion-one: $removed_env is no longer supported; Typhon starts natively." >&2
        exit 1
    fi
done

if [[ "$profile" == "auto" ]]; then
    profile="release"
fi

export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-OblivionOne}"
export XDG_SESSION_DESKTOP="${XDG_SESSION_DESKTOP:-OblivionOne}"
export DESKTOP_SESSION="${DESKTOP_SESSION:-oblivion-one}"

# Host display variables are irrelevant to native startup. Remove them before
# the compositor starts so only Typhon's own Wayland socket is used by children.
unset WAYLAND_DISPLAY
unset WAYLAND_SOCKET
unset DISPLAY

command=()
if [[ "$profile" == "release" ]]; then
    release_binary="$repo_dir/target/release/oblivion-one"
    command=("$release_binary" compositor --socket "$socket" "$@")
elif [[ "$profile" == "debug" ]]; then
    command=(cargo run --manifest-path "$repo_dir/Cargo.toml" -- compositor --socket "$socket" "$@")
else
    echo "start-oblivion-one: OBLIVION_ONE_PROFILE must be auto, debug, or release, got '$profile'" >&2
    exit 1
fi

warn_native_input_permissions

if [[ "${OBLIVION_ONE_DRY_RUN:-0}" == "1" ]]; then
    printf '%q ' "${command[@]}"
    printf '\n'
    exit 0
fi

if [[ "$profile" == "release" && ! -x "${command[0]}" ]]; then
    echo "start-oblivion-one: missing release binary: ${command[0]}" >&2
    echo "start-oblivion-one: build it before selecting the SDDM session: cargo build --release --manifest-path $repo_dir/Cargo.toml" >&2
    exit 1
fi

mkdir -p -- "$(dirname -- "$log_file")"
{
    printf '\n[%s] start-oblivion-one runtime=native profile=%s socket=%s\n' "$(date --iso-8601=seconds)" "$profile" "$socket"
    printf '[%s] native launch broker=typhon-shell-control display=unset-before-compositor\n' "$(date --iso-8601=seconds)"
    printf '[%s] command:' "$(date --iso-8601=seconds)"
    printf ' %q' "${command[@]}"
    printf '\n'
} >>"$log_file"
exec >> >(tee -a "$log_file") 2>&1

exec "${command[@]}"
