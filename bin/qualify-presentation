#!/usr/bin/env bash
set -euo pipefail

script_path="${BASH_SOURCE[0]}"
while [[ -L "$script_path" ]]; do
    script_dir="$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)"
    link_target="$(readlink -- "$script_path")"
    if [[ "$link_target" == /* ]]; then
        script_path="$link_target"
    else
        script_path="$script_dir/$link_target"
    fi
done
script_dir="$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)"

dry_run=0
for argument in "$@"; do
    case "$argument" in
        --dry-run) dry_run=1 ;;
        --help|-h)
            cat <<'EOF'
qualify-presentation

Run or print the labeled direct-scanout/fullscreen qualification matrix.

Options:
  --dry-run  print the sequential matrix without starting a session

For live runs, set OBLIVION_ONE_QUALIFY_COMMAND to the command that owns one
session. Each phase receives its own labeled directory and environment.
EOF
            exit 0
            ;;
        *)
            echo "qualify-presentation: unknown argument: $argument" >&2
            exit 2
            ;;
    esac
done

state_root="${OBLIVION_ONE_QUALIFICATION_ROOT:-${XDG_STATE_HOME:-$HOME/.local/state}/oblivion-one/qualifications}"
run_root="$state_root/$(date +%Y%m%d-%H%M%S)"
qualify_command="${OBLIVION_ONE_QUALIFY_COMMAND:-$script_dir/start-oblivion-one-tty}"
duration_seconds="${OBLIVION_ONE_QUALIFY_DURATION_SECONDS:-120}"

run_phase() {
    local direct="$1"
    local triple="$2"
    local cursor="$3"
    local phase="direct-${direct}_triple-${triple}_cursor-${cursor}"
    local phase_dir="$run_root/$phase"
    local session_log="$phase_dir/session.log"
    local trace_log="$phase_dir/presentation-trace.jsonl"
    local metrics_file="$phase_dir/metrics.json"
    local environment_file="$phase_dir/environment.txt"
    local summary_file="$phase_dir/summary.txt"

    if [[ "$dry_run" == "1" ]]; then
        printf 'phase=%s direct=%s triple=%s cursor=%s command=%q\n' \
            "$phase" "$direct" "$triple" "$cursor" "$qualify_command"
        return
    fi

    mkdir -p -- "$phase_dir"
    printf '{"events":[],"dropped":0}\n' >"$trace_log"
    printf '{}\n' >"$metrics_file"
    {
        printf 'phase=%s\n' "$phase"
        printf 'direct=%s\ntriple=%s\ncursor=%s\n' "$direct" "$triple" "$cursor"
        printf 'started=%s\n' "$(date --iso-8601=seconds)"
        env | sort
    } >"$environment_file"

    printf '[%s] phase=%s\n' "$(date --iso-8601=seconds)" "$phase" | tee "$session_log"
    (
        export OBLIVION_ONE_DIRECT_SCANOUT="$direct"
        export OBLIVION_ONE_TRIPLE_BUFFERING="$triple"
        export OBLIVION_ONE_CURSOR_SCHEDULING="$cursor"
        export OBLIVION_ONE_PRESENTATION_TRACE=1
        export OBLIVION_ONE_PRESENTATION_TRACE_CAPACITY=4096
        export OBLIVION_ONE_PRESENTATION_TRACE_FILE="$trace_log"
        export OBLIVION_ONE_LOG_FILE="$session_log"
        timeout --signal=TERM --kill-after=5s "${duration_seconds}s" \
            "$qualify_command"
    ) 2>&1 | tee -a "$session_log" || true
    if [[ -f "$trace_log" ]]; then
        truncate -s 4194304 "$trace_log"
    fi

    {
        printf 'phase=%s\n' "$phase"
        printf 'unique_buffers=%s\n' "$(grep -c 'direct_scanout_buffer=' "$session_log" 2>/dev/null || true)"
        printf 'transactions=%s\n' "$(grep -c 'native.direct_scanout' "$session_log" 2>/dev/null || true)"
        printf 'kms_submits=%s\n' "$(grep -c 'transition=submit' "$session_log" 2>/dev/null || true)"
        printf 'same_buffer_submits=%s\n' "$(grep -c 'same_buffer' "$session_log" 2>/dev/null || true)"
        printf 'pageflips=%s\n' "$(grep -c 'pageflip' "$session_log" 2>/dev/null || true)"
        printf 'trace_dropped=%s\n' "$(grep -o 'presentation_trace_dropped=[0-9]*' "$session_log" 2>/dev/null | tail -1 | cut -d= -f2 || true)"
        printf 'completed=%s\n' "$(date --iso-8601=seconds)"
    } | tee "$summary_file"
}

if [[ "$dry_run" == "0" ]]; then
    mkdir -p -- "$run_root"
    printf 'qualification_root=%s\n' "$run_root"
fi

for direct in off experimental-auto; do
    for triple in off auto force; do
        for cursor in auto piggyback software; do
            run_phase "$direct" "$triple" "$cursor"
        done
    done
done
