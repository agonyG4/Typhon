#!/usr/bin/env bash
set -euo pipefail

prod_limit=1500
test_limit=2000
mod_limit=800

allowed_oversized() {
    case "$1" in
        src/compositor/render.rs) return 0 ;;
        src/egl_renderer.rs) return 0 ;;
        src/nested_output.rs) return 0 ;;
        *) return 1 ;;
    esac
}

limit_for() {
    local path="$1"
    if [[ "$(basename "$path")" == "mod.rs" ]]; then
        printf '%s\n' "$mod_limit"
    elif [[ "$path" == *"/tests/"* || "$path" == *"_tests.rs" ]]; then
        printf '%s\n' "$test_limit"
    else
        printf '%s\n' "$prod_limit"
    fi
}

status=0
if rg -n 'include!\s*\(' src >/tmp/typhon-source-layout-includes 2>/dev/null; then
    while IFS= read -r match; do
        printf 'source-layout: architecture include! is not allowed: %s\n' "$match" >&2
    done </tmp/typhon-source-layout-includes
    status=1
fi

while IFS= read -r -d '' path; do
    case "$path" in
        target/*|*/target/*|.git/*) continue ;;
    esac
    lines=$(wc -l < "$path")
    limit=$(limit_for "$path")
    if (( lines > limit )) && ! allowed_oversized "$path"; then
        printf 'source-layout: %s has %s lines, limit is %s\n' "$path" "$lines" "$limit" >&2
        status=1
    fi
done < <(find src -type f -name '*.rs' -print0)

python3 - <<'PY' || status=1
from pathlib import Path
import re
import sys

roots = [
    Path("src/native_output/tests"),
    Path("src/compositor/tests"),
]
mod_re = re.compile(r"^\s*(?:pub(?:\([^)]*\))?\s+)?mod\s+([A-Za-z0-9_]+)\s*;", re.MULTILINE)

def visit(path: Path, seen: set[Path]) -> None:
    path = path.resolve()
    if path in seen or not path.exists():
        return
    seen.add(path)
    text = path.read_text()
    base = path.parent
    for name in mod_re.findall(text):
        file_child = base / f"{name}.rs"
        dir_child = base / name / "mod.rs"
        if file_child.exists():
            visit(file_child, seen)
        elif dir_child.exists():
            visit(dir_child, seen)
        else:
            print(
                f"source-layout: {path.relative_to(Path.cwd())} declares missing test module {name}",
                file=sys.stderr,
            )
            raise SystemExit(1)

for root in roots:
    if not root.exists():
        continue
    seen: set[Path] = set()
    visit(root / "mod.rs", seen)
    retained = {path.resolve() for path in root.rglob("*.rs")}
    missing = sorted(retained - seen)
    for path in missing:
        print(
            f"source-layout: disconnected test source {path.relative_to(Path.cwd())}",
            file=sys.stderr,
        )
    if missing:
        raise SystemExit(1)
PY

exit "$status"
