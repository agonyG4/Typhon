<?xml version="1.0" encoding="UTF-8"?>
<protocol name="astrea_shell_control_v1">
  <copyright>
    Copyright 2026 Astrea
  </copyright>

  <interface name="astrea_shell_control_manager_v1" version="1">
    <enum name="error">
      <entry name="unauthorized" value="0"/>
      <entry name="invalid_desktop_id" value="1"/>
      <entry name="invalid_argv_json" value="2"/>
    </enum>

    <request name="launch_desktop">
      <arg name="request" type="new_id" interface="astrea_launch_request_v1"/>
      <arg name="desktop_id" type="string"/>
    </request>

    <request name="launch_argv_json">
      <arg name="request" type="new_id" interface="astrea_launch_request_v1"/>
      <arg name="argv_json" type="string"/>
    </request>

    <request name="destroy" type="destructor"/>
  </interface>

  <interface name="astrea_launch_request_v1" version="1">
    <description summary="supervised Astrea shell-control launch">
      accepted means supervision began for the reported PID. A successful
      accepted request emits exactly one finished event after that exact child
      exits. Destroying the request removes only the Wayland observer; it does
      not kill the supervised child.
    </description>

    <event name="accepted">
      <arg name="pid" type="uint"/>
    </event>

    <event name="failed">
      <arg name="code" type="uint"/>
      <arg name="message" type="string"/>
    </event>

    <event name="finished">
      <description summary="supervised child completion">
        status is the normal exit code from 0 through 255, or the negative
        signal number when the child was terminated by signal. -255 is used
        when the platform provides neither a normal exit code nor a signal.
      </description>
      <arg name="status" type="int"/>
    </event>

    <request name="destroy" type="destructor"/>
  </interface>
</protocol>
